{{#if (or (includes transports 'streamable') (includes transports 'sse'))}}
import { nanoid } from 'nanoid'

export function generateSessionId() {
  return nanoid()
}

{{/if}}
export function getOptions(argv, pkg) {
  return {
    name: pkg.name,
    version: pkg.version,
{{#if (or (includes transports 'streamable') (includes transports 'sse'))}}
    port: argv.port,
{{/if}}
  }
}
