{
  "name": "{{projectName}}",
  "version": "0.0.0",
  "description": "{{projectName}}",
  "author": "zhensherlock",
  "type": "module",
  "license": "MIT",
  "files": [
    "build",
    "LICENSE",
    "README.md"
  ],
  "main": "build/index.js",
  "scripts": {
{{#if (includes plugins 'style')}}
    "lint": "npx eslint \"src/**/*.{ts,js}\"",
{{/if}}
    "build": "tsc --noEmit && cross-env NODE_ENV=production node scripts/build.js",
    "dev": "cross-env NODE_ENV=local concurrently \"tsc --noEmit --watch\" \"node scripts/dev.js\"",
{{#if (includes plugins 'vitest')}}
    "test": "vitest run",
    "coverage": "rimraf coverage && vitest run --coverage",
{{/if}}
{{#if (includes plugins 'changelog')}}
    "changelog": "conventional-changelog -p angular -i CHANGELOG.md -s -r 0 -n changelog-option.js",
{{/if}}
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2"
  },
  "devDependencies": {
{{#if (includes plugins 'commitlint')}}
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
{{/if}}
{{#if (includes plugins 'style')}}
    "typescript-eslint": "^8.65.0",
{{/if}}
{{#if (includes plugins 'vitest')}}
    "@vitest/coverage-v8": "^4.1.10",
{{/if}}
{{#if (includes plugins 'changelog')}}
    "compare-func": "^2.0.0",
{{/if}}
    "concurrently": "^10.0.3",
{{#if (includes plugins 'changelog')}}
    "conventional-changelog-angular": "^8.3.1",
    "conventional-changelog-cli": "^5.0.0",
{{/if}}
    "cross-env": "^10.1.0",
    "esbuild": "^0.28.1",
{{#if (includes plugins 'style')}}
    "eslint": "^9.39.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
{{/if}}
    "husky": "^9.1.7",
{{#if (includes plugins 'style')}}
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
{{/if}}
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
{{#if (includes plugins 'vitest')}}
    "vitest": "^4.1.10",
{{/if}}
    "rimraf": "^6.1.3"
  }
}
