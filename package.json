{
  "name": "mcp-kit",
  "version": "1.0.0",
  "description": "A CLI tool to create MCP (Model Context Protocol) applications with ease.",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "cross-env NODE_ENV=development turbo run dev",
    "build": "cross-env NODE_ENV=production turbo run build",
    "test": "cross-env NODE_V8_COVERAGE=./coverage/tmp vitest run",
    "coverage": "rimraf coverage && cross-env NODE_V8_COVERAGE=./coverage/tmp vitest run && npm run report",
    "report": "c8 report --reporter=lcov --reporter=html",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "author": "zhensherlock",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/my-mcp-hub/mcp-kit/issues"
  },
  "homepage": "https://my-mcp-hub.github.io/mcp-kit/",
  "keywords": [
    "mcp",
    "mcp server",
    "mcp client",
    "mcp host",
    "mcp kit",
    "mcp tool kit",
    "mcp cli",
    "cli",
    "cli tool",
    "create mcp",
    "create mcp server",
    "create mcp client",
    "create mcp host",
    "modelcontextprotocol",
    "typescript"
  ],
  "packageManager": "pnpm@10.34.5",
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^22.20.1",
    "@vitest/coverage-v8": "^4.1.10",
    "c8": "^12.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.6",
    "execa": "^10.0.0",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.1",
    "prettier": "^3.9.6",
    "rimraf": "^6.1.3",
    "rolldown": "^1.2.0",
    "tsx": "^4.23.1",
    "turbo": "^2.10.6",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.65.0",
    "vitest": "^4.1.10"
  }
}
