{
  "name": "mcp-kit",
  "version": "1.0.0",
  "description": "A CLI tool to create MCP (Model Context Protocol) applications with ease.",
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "cross-env NODE_ENV=development turbo run dev",
    "build": "cross-env NODE_ENV=production turbo run build",
    "test": "cross-env NODE_V8_COVERAGE=./coverage/tmp vitest run",
    "coverage": "rimraf coverage && cross-env NODE_V8_COVERAGE=./coverage/tmp vitest run && npm run report",
    "report": "c8 report --reporter=lcov --reporter=html",
    "changeset": "changeset",
    "version": "changeset version"
  },
  "author": "zhensherlock",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/my-mcp-hub/mcp-kit/issues"
  },
  "homepage": "https://my-mcp-hub.github.io/mcp-kit/",
  "keywords": [
    "mcp",
    "mcp server",
    "mcp client",
    "mcp host",
    "mcp kit",
    "mcp tool kit",
    "mcp cli",
    "cli",
    "cli tool",
    "create mcp",
    "create mcp server",
    "create mcp client",
    "create mcp host",
    "modelcontextprotocol",
    "typescript"
  ],
  "packageManager": "pnpm@10.33.0",
  "devDependencies": {
    "@biomejs/biome": "2.3.14",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.30.0",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^22.19.17",
    "@vitest/coverage-v8": "^4.1.2",
    "c8": "^11.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "execa": "^9.6.1",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "rolldown": "^1.0.0-rc.13",
    "tsx": "^4.21.0",
    "turbo": "^2.9.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.0",
    "vitest": "^4.1.2"
  }
}
